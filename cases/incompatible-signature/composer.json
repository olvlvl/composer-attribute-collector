{
  "repositories": [
    {
      "type": "path",
      "url": "composer-attribute-collector"
    }
  ],
  "require": {
    "php": ">=8.0",
    "psr/log": "^3.0",
    "olvlvl/composer-attribute-collector": "@dev"
  },
  "config": {
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true
    }
  },
  "extra": {
    "composer-attribute-collector": {
      "include": [
        "src"
      ]
    }
  },
  "autoload": {
    "psr-4": {
      "Acme\\": "src"
    }
  }
}
